#!/bin/bash
# arch-installer — launcher script for the GTK3 Arch Linux installer
# Run as root: sudo ./arch-installer

set -e

# ── Root check ────────────────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then
    echo ""
    echo "  ✗ This installer must be run as root."
    echo "    Try: sudo ./arch-installer"
    echo ""
    exit 1
fi

# ── Arch check ────────────────────────────────────────────────────────────────
if [[ ! -f /etc/arch-release ]]; then
    echo ""
    echo "  ✗ This installer is designed for Arch Linux only."
    echo ""
    exit 1
fi

# ── Expand cowspace (live ISO RAM disk is small) ──────────────────────────────
if mountpoint -q /run/archiso/cowspace 2>/dev/null; then
    echo "  → Expanding cowspace to 2G for package installation..."
    mount -o remount,size=2G /run/archiso/cowspace 2>/dev/null || true
fi

# ── Dependency check and install ─────────────────────────────────────────────
DEPS=(
    python
    python-gobject
    python-cairo
    python-pytz
    gtk3
    webkit2gtk-4.1
    gobject-introspection
)

MISSING=()
for pkg in "${DEPS[@]}"; do
    if ! pacman -Qi "$pkg" &>/dev/null; then
        MISSING+=("$pkg")
    fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
    echo ""
    echo "  → Installing missing dependencies: ${MISSING[*]}"
    echo ""
    pacman -Sy --noconfirm --overwrite '*' "${MISSING[@]}"
    echo ""
    echo "  ✓ Dependencies installed."
    echo ""
else
    echo "  ✓ All dependencies present."
fi

# ── Verify gi is importable ───────────────────────────────────────────────────
if ! python3 -c "import gi" &>/dev/null; then
    echo ""
    echo "  ✗ Failed to import Python GObject Introspection (gi) module."
    echo "    Try running: pacman -Sy --overwrite '*' python-gobject"
    echo ""
    exit 1
fi

# ── Launch installer ──────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

echo "  → Launching Arch Installer..."
echo ""

exec python3 -m installer.main
